{
    "name": "codex-usage",
    "displayName": "CodexUsage",
    "description": "A CLI tool to analyze and report on the usage of OpenAI's Codex.",
    "version": "1.1.3",
    "author": "@CaptainStarbuck (https://discord.gg/openai #codex-discussions)",
    "license": "MIT",
    "homepage": "https://github.com/CaptainStarbuck/codex-usage",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/CaptainStarbuck/codex-usage.git"
    },
    "bugs": {
        "url": "https://github.com/CaptainStarbuck/codex-usage/issues"
    },
    "keywords": [
        "codex",
        "tokens",
        "quota",
        "usage",
        "reporting"
    ],
    "private": true,
    "type": "module",
    "bin": {
        "codex-usage": "./src/codex-usage.js"
    },
    "scripts": {
        "run:install": "pnpm install",
        "lint": "pnpm exec eslint",
        "format:src": "pnpm exec prettier --config prettier.config.js --write \"src/**/*.{cjs,mjs,js,ts}\"",
        "format:docs": "pnpm exec prettier --config prettier.config.js --write \"./*.md\" --write \"docs/**/*.md\""
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@eslint/json": "^1.2.0",
        "@types/node": "^25.6.0",
        "eslint": "^10.2.1",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsonc": "^3.1.2",
        "fast-glob": "^3.3.3",
        "globals": "^17.5.0",
        "prettier": "^3.8.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.1"
    },
    "packageManager": "pnpm@10.33.2"
}
