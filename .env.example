DATA_PATH=/tmp/codex-usage
DATA_PATH_WINDOWS_DEFAULT=C:\Temp\codex-usage
CODEX_HOME=
STYLES=styles-dark-01.css
DATETIME_FORMAT=MMM D, h:mm AP
# Ref `docs/datetime.md` for formatting options.
RANGE_SCOPE=events
IN_SCOPE=false
MAX_EVENTS=500
MAX_SESSIONS=500
MAX_FILES=0
MAX_TURNS=0
MAX_MODELS=0

# Use quotes on paths with spaces.
# DATA_PATH="/tmp/codex usage"
# CODEX_HOME="C:\Users\example\OpenAI Codex"
